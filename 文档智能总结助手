// ========== 1. 主题切换 ==========
themeBtn.addEventListener("click", () => {
    const now = document.documentElement.getAttribute("data-theme");
    if (now === "dark") {
        document.documentElement.removeAttribute("data-theme");
        localStorage.setItem("theme", "light");
    } else {
        document.documentElement.setAttribute("data-theme", "dark");
        localStorage.setItem("theme", "dark");
    }
});
const savedTheme = localStorage.getItem("theme");
if (savedTheme === "dark") document.documentElement.setAttribute("data-theme", "dark");

// ========== 2. PDF解析（保留段落结构） ==========
async function readPdf(file) {
    const arrayBuffer = await file.arrayBuffer();
    const pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;
    let fullText = "";
    
    for (let i = 1; i <= pdf.numPages; i++) {
        const page = await pdf.getPage(i);
        const content = await page.getTextContent();
        
        // 按y坐标重组文本，保留换行结构
        let pageText = "";
        let lastY = null;
        content.items.forEach(item => {
            const y = Math.floor(item.transform[5]);
            if (lastY !== null && y < lastY - 5) {
                pageText += "\n";
            } else if (lastY !== null) {
                pageText += " ";
            }
            pageText += item.str;
            lastY = y;
        });
        
        fullText += pageText + "\n\n";
    }
    
    return fullText.trim();
}

// ========== 3. 精准句子统计（仅保留。！？.?!） ==========
function statText(text) {
    // 纯文字数（去空格）
    const pure = text.replace(/\s+/g, "");
    // 段落数（过滤空行）
    const paras = text.split("\n").filter(p => p.trim());
    
    // 仅以 。！？ . ! ? 作为句子分隔符
    const sentenceRegex = /([。！？.?!])\s*/g;
    const sentences = text.split(sentenceRegex)
        .filter(s => s.trim() && !sentenceRegex.test(s)) // 过滤空内容和纯标点
        .map(s => s.trim())
        .filter(Boolean);

    return {
        chars: pure.length,
        paraCnt: paras.length,
        sentCnt: sentences.length
    };
}

// ========== 4. 全文阅读弹窗 ==========
window.openFullText = (title, text) => {
    fullTitle.textContent = title;
    fullContent.textContent = text;
    fullModal.style.display = "flex";
};
closeFull.addEventListener("click", () => fullModal.style.display = "none");

// ========== 5. 翻译功能（复制按钮替换导出） ==========
window.translateSummary = async function(content, filename) {
    try {
        translatePanel.style.display = "block";
        translateContent.textContent = "翻译中...";
        
        const prompt = `将以下总结内容翻译成英文，保持原意和格式：\n${content}`;
        const res = await fetch(DEEPSEEK_URL, {
            method: "POST",
            headers: {
                "Authorization": "Bearer " + DEEPSEEK_API_KEY,
                "Content-Type": "application/json"
            },
            body: JSON.stringify({
                model: MODEL_NAME,
                messages: [{ role: "user", content: prompt }],
                temperature: 0.2
            })
        });
        
        const data = await res.json();
        if (data.error) throw new Error(data.error.message);
        
        // 存储翻译结果
        currentTranslateContent = data.choices[0].message.content;
        translateContent.textContent = currentTranslateContent;
    } catch (e) {
        translateContent.textContent = `翻译失败：${e.message}`;
        currentTranslateContent = "";
    }
};

// 复制翻译结果
copyTranslateBtn.addEventListener("click", () => {
    if (!currentTranslateContent) {
        alert("暂无翻译结果可复制");
        return;
    }
    navigator.clipboard.writeText(currentTranslateContent).then(() => {
        alert("翻译结果已复制到剪贴板！");
    }).catch(() => {
        alert("复制失败，请手动复制");
    });
});

// ========== 6. 通用导出功能（仅保留对比结果导出） ==========
function exportToTxt(filename, content) {
    const blob = new Blob([content], { type: "text/plain;charset=utf-8" });
    const a = document.createElement("a");
    a.href = URL.createObjectURL(blob);
    a.download = `${filename}.txt`;
    a.click();
    URL.revokeObjectURL(a.href);
}

function exportToDocx(filename, content) {
    try {
        const zip = new PizZip();
        zip.file("document.xml", `
            <w:document xmlns:w="http://schemas.openxmlformats.org/wordprocessingml/2006/main">
                <w:body>
                    <w:p>
                        <w:r>
                            <w:t xml:space="preserve">${content.replace(/\n/g, "</w:t></w:r></w:p><w:p><w:r><w:t xml:space=\"preserve\">")}</w:t>
                        </w:r>
                    </w:p>
                </w:body>
            </w:document>
        `);
        const blob = zip.generate({ type: "blob" });
        const a = document.createElement("a");
        a.href = URL.createObjectURL(blob);
        a.download = `${filename}.docx`;
        a.click();
        URL.revokeObjectURL(a.href);
    } catch (e) {
        alert("DOCX导出失败，将自动导出为TXT：" + e.message);
        exportToTxt(filename, content);
    }
}

// ========== 7. 错误重试机制 ==========
window.retryProcess = async function(filename, ext, fullText) {
    try {
        resultsDiv.innerHTML = renderCard({ 
            filename, ext, 
            chars: statText(fullText).chars,
            paraCnt: statText(fullText).paraCnt,
            sentCnt: statText(fullText).sentCnt,
            preview: fullText.slice(0,600) + (fullText.length>600?"…":""),
            summary: null, 
            keywords: null, 
            fullText 
        });
        
        const [sum, kw] = await Promise.all([aiSummary(fullText), extractKeywords(fullText)]);
        const final = { 
            filename, ext, 
            ...statText(fullText),
            preview: fullText.slice(0,600) + (fullText.length>600?"…":""),
            summary: sum, 
            keywords: kw, 
            fullText 
        };
        
        resultsDiv.innerHTML = renderCard(final);
        const history = getHistory();
        const idx = history.findIndex(item => item.filename === filename);
        if (idx > -1) {
            history[idx] = { ...history[idx], summary: sum, keywords: kw };
            localStorage.setItem("docSummaryHistory", JSON.stringify(history));
            renderHistory();
        } else {
            saveHistory(final);
        }
    } catch (e) {
        resultsDiv.innerHTML = renderCard({ 
            filename, ext, 
            chars: "-", paraCnt: "-", sentCnt: "-",
            preview: "失败", 
            summary: e.message, 
            keywords: null, 
            fullText: "" 
        });
    }
};

// ========== 8. 文档对比功能 ==========
function setupCompareDrop(dropEl, selectBtn, fileNum) {
    dropEl.addEventListener("dragover", e => { e.preventDefault(); dropEl.classList.add("dragover"); });
    dropEl.addEventListener("dragleave", () => dropEl.classList.remove("dragover"));
    dropEl.addEventListener("drop", e => {
        e.preventDefault();
        dropEl.classList.remove("dragover");
        if (e.dataTransfer.files.length) loadCompareFile(e.dataTransfer.files[0], dropEl, fileNum);
    });
    selectBtn.addEventListener("click", () => {
        const inp = document.createElement("input");
        inp.type = "file"; inp.accept = ".txt,.docx,.pdf";
        inp.onchange = e => {
            if (e.target.files.length) loadCompareFile(e.target.files[0], dropEl, fileNum);
        };
        inp.click();
    });
}

setupCompareDrop(compareDrop1, compareSelect1, 1);
setupCompareDrop(compareDrop2, compareSelect2, 2);

async function loadCompareFile(file, dropEl, num) {
    try {
        let text = "";
        const ext = file.name.split(".").pop().toLowerCase();
        if (ext === "txt") text = await readTxt(file);
        else if (ext === "docx") text = await readDocx(file);
        else if (ext === "pdf") text = await readPdf(file);
        else { alert("仅支持 txt/docx/pdf"); return; }
        const stat = statText(text); // 精准句子统计
        if (num === 1) {
            compareFile1 = { name: file.name, text, stat };
        } else {
            compareFile2 = { name: file.name, text, stat };
        }
        dropEl.innerHTML = `<p style="margin:0;">✅ ${file.name}</p>`;
        checkCompareReady();
    } catch (e) { alert("读取失败：" + e.message); }
}

function checkCompareReady() {
    startCompareBtn.disabled = !(compareFile1.text && compareFile2.text);
}

startCompareBtn.addEventListener("click", async () => {
    if (!DEEPSEEK_API_KEY || DEEPSEEK_API_KEY.includes("粘贴")) {
        alert("请填写 API Key");
        return;
    }
    startCompareBtn.disabled = true;
    exportCompareBtn.disabled = true;
    compareResult.textContent = "正在对比...";

    const s1 = compareFile1.stat;
    const s2 = compareFile2.stat;

    // 勾选的对比维度
    const selectedDims = [];
    if (dimContent.checked) selectedDims.push("内容差异");
    if (dimKeyword.checked) selectedDims.push("关键词差异");
    if (dimView.checked) selectedDims.push("核心观点/重点差异");
    if (dimStructure.checked) selectedDims.push("结构/逻辑差异");
    if (dimData.checked) selectedDims.push("数据/案例差异");

    if (selectedDims.length === 0) {
        alert("请至少选择一个对比维度");
        startCompareBtn.disabled = false;
        compareResult.textContent = "";
        return;
    }

    const basic = `【基础信息对比】
文档1：${compareFile1.name}
文档2：${compareFile2.name}
总字数：${s1.chars} vs ${s2.chars}
段落数：${s1.paraCnt} vs ${s2.paraCnt}
句子数：${s1.sentCnt} vs ${s2.sentCnt}

【AI 内容对比】正在分析...`;

    compareResult.textContent = basic;

    try {
        const dimText = selectedDims.join("、");
        const prompt = `
请对比下面两份文档，仅针对【${dimText}】维度，用中文分点清晰输出：
${selectedDims.map((dim, idx) => `${idx+1}. ${dim}`).join("\n")}
文档1：
${compareFile1.text.slice(0, 8000)}

文档2：
${compareFile2.text.slice(0, 8000)}`;

        const res = await fetch(DEEPSEEK_URL, {
            method: "POST",
            headers: {
                "Authorization": "Bearer " + DEEPSEEK_API_KEY,
                "Content-Type": "application/json"
            },
            body: JSON.stringify({
                model: MODEL_NAME,
                messages: [{ role: "user", content: prompt }],
                temperature: 0.4,
                max_tokens: 1500
            })
        });
        const data = await res.json();
        const ai = data.choices?.[0]?.message.content || "对比失败";
        const finalResult = `${basic.replace("正在分析...", "")}\n${ai}`;
        compareResult.textContent = finalResult;
        currentCompareResult = finalResult;
        exportCompareBtn.disabled = false;
    } catch (e) {
        compareResult.textContent = `${basic.replace("正在分析...", "失败：" + e.message)}`;
    }
    startCompareBtn.disabled = false;
});

// 对比结果导出
exportCompareBtn.addEventListener("click", () => {
    if (!currentCompareResult) return;
    const type = prompt("请选择导出格式：\n1 - TXT\n2 - DOCX", "1");
    const filename = `${compareFile1.name}_VS_${compareFile2.name}_对比结果`;
    if (type === "1") {
        exportToTxt(filename, currentCompareResult);
    } else if (type === "2") {
        exportToDocx(filename, currentCompareResult);
    }
});

// ========== 9. 文档总结核心功能 ==========
window.addEventListener("dragover", e => e.preventDefault());
window.addEventListener("drop", e => e.preventDefault());

dropArea.addEventListener("dragover", e => { e.preventDefault(); dropArea.classList.add("dragover"); });
dropArea.addEventListener("dragleave", () => dropArea.classList.remove("dragover"));
dropArea.addEventListener("drop", e => {
    e.preventDefault();
    dropArea.classList.remove("dragover");
    processFiles(Array.from(e.dataTransfer.files));
});

selectBtn.addEventListener("click", () => {
    const inp = document.createElement("input");
    inp.type = "file"; inp.multiple = true; inp.accept = ".docx,.txt,.pdf";
    inp.onchange = e => processFiles(Array.from(e.target.files));
    inp.click();
});

async function readTxt(file) {
    return new Promise((resolve, reject) => {
        const r = new FileReader();
        r.onload = () => resolve(r.result);
        r.onerror = reject;
        r.readAsText(file, "utf-8");
    });
}

async function readDocx(file) {
    const buf = await file.arrayBuffer();
    const r = await mammoth.extractRawText({ arrayBuffer: buf });
    return r.value;
}

async function aiSummary(text) {
    const max = parseInt(wordLimitInput.value) || 300;
    const style = styleSelect.value;
    let prompt = "";

    if (style === "concise") {
        prompt = `请用极简要点总结，只保留最核心结论，不要分点、不要解释、不要细节，越短越好，严格控制在${max}字内：
${text}`;
    } else if (style === "detailed") {
        prompt = `请做详细完整总结，保留逻辑、背景、关键细节、过程和结论，内容充实有条理，尽量接近${max}字，不冗余、不省略重点：
${text}`;
    } else {
        prompt = `流畅自然总结，≤${max}字：
${text}`;
    }

    const res = await fetch(DEEPSEEK_URL, {
        method: "POST",
        headers: {
            "Authorization": "Bearer " + DEEPSEEK_API_KEY,
            "Content-Type": "application/json"
        },
        body: JSON.stringify({
            model: MODEL_NAME,
            messages: [{ role: "user", content: prompt }],
            temperature: style === "creative" ? 0.7 : 0.2,
            max_tokens: 1000
        })
    });
    const data = await res.json();
    if (data.error) throw new Error(data.error.message);
    let r = data.choices[0].message.content;
    if (r.length > max + 20) {
        const t = r.slice(0, max);
        const last = Math.max(t.lastIndexOf("。"), t.lastIndexOf("！"), t.lastIndexOf("？"));
        r = last > 0 ? t.slice(0, last + 1) : t;
    }
    return r;
}

async function extractKeywords(text) {
    const p = "提取5-10个关键词，逗号分隔：\n" + text;
    const r = await fetch(DEEPSEEK_URL, {
        method: "POST",
        headers: {
            "Authorization": "Bearer " + DEEPSEEK_API_KEY,
            "Content-Type": "application/json"
        },
        body: JSON.stringify({ model: MODEL_NAME, messages: [{ role: "user", content: p }], temperature: 0.3 })
    });
    const d = await r.json();
    return d.choices?.[0]?.message.content || "无";
}

window.copySummary = function(t) { 
    navigator.clipboard.writeText(t).then(() => alert("已复制！")); 
};

function renderCard(item) {
    const cnt = item.summary ? `<div class="char-count">${item.summary.length} 字</div>` : "";
    const kw = item.keywords ? `<div class="keywords"><strong>关键词：</strong>${item.keywords}</div>` : "";
    
    // 按钮组
    const readBtn = item.fullText
        ? `<button class="btn btn-sm" onclick="openFullText('${item.filename}', \`${item.fullText.replace(/`/g, '')}\`)">完整阅读</button>`
        : "";
    const copyBtn = item.summary
        ? `<button class="btn btn-sm" onclick="copySummary(\`${item.summary.replace(/`/g, '')}\`)">一键复制</button>`
        : "";
    const exportBtn = item.summary
        ? `<button class="btn btn-sm" onclick="exportSummary('${item.filename}', \`${item.summary.replace(/`/g, '')}\`)">导出总结</button>`
        : "";
    const translateBtn = item.summary
        ? `<button class="btn btn-sm" onclick="translateSummary(\`${item.summary.replace(/`/g, '')}\`, '${item.filename}')">翻译总结</button>`
        : "";
    const retryBtn = item.summary && item.summary.includes("失败")
        ? `<button class="btn btn-sm" style="background:#ef4444;" onclick="retryProcess('${item.filename}', '${item.ext}', \`${item.fullText.replace(/`/g, '')}\`)">重试</button>`
        : "";

    return `
    <div class="card">
        <h4>${item.filename}</h4>
        <div class="info">
            <div>字数：${item.chars}</div>
            <div>段落：${item.paraCnt}</div>
            <div>句子：${item.sentCnt}</div>
            <div>类型：${item.ext}</div>
        </div>
        <div class="preview"><pre>${item.preview}</pre></div>
        <div class="summary">${item.summary || '<span class="loading">生成中…</span>'}</div>
        ${cnt}${kw}
        <div class="copy-row">${readBtn} ${copyBtn} ${exportBtn} ${translateBtn} ${retryBtn}</div>
    </div>`;
}

window.exportSummary = function(filename, content) {
    const type = prompt("请选择导出格式：\n1 - TXT\n2 - DOCX", "1");
    if (type === "1") {
        exportToTxt(`${filename}_总结`, content);
    } else if (type === "2") {
        exportToDocx(`${filename}_总结`, content);
    }
};

// ========== 10. 历史记录功能 ==========
function getHistory() { return JSON.parse(localStorage.getItem("docSummaryHistory") || "[]"); }
function saveHistory(item) {
    const h = getHistory();
    h.unshift({ id: Date.now(), time: new Date().toLocaleString(), ...item });
    localStorage.setItem("docSummaryHistory", JSON.stringify(h));
    renderHistory();
}
function deleteHistory(id) {
    const h = getHistory().filter(x => x.id !== id);
    localStorage.setItem("docSummaryHistory", JSON.stringify(h));
    renderHistory();
}
function clearAllHistory() { 
    if (confirm("确定清空历史记录？")) { 
        localStorage.removeItem("docSummaryHistory"); 
        renderHistory(); 
    } 
}
function renderHistory() {
    const h = getHistory();
    if (!h.length) { 
        historyList.innerHTML = '<div class="empty-history">暂无记录</div>'; 
        return; 
    }
    historyList.innerHTML = h.map(x => `
    <div class="history-item" onclick="loadHistory(${x.id})">
        <div><div class="name">${x.filename}</div><div class="time">${x.time}</div></div>
        <button class="del" onclick="event.stopPropagation();deleteHistory(${x.id})">删除</button>
    </div>`).join("");
}
function loadHistory(id) {
    const item = getHistory().find(x => x.id === id);
    if (item) resultsDiv.innerHTML = renderCard(item);
}

clearHistoryBtn.addEventListener("click", clearAllHistory);
window.loadHistory = loadHistory;
window.deleteHistory = deleteHistory;
renderHistory();

// 处理文件入口
async function processFiles(files) {
    if (!DEEPSEEK_API_KEY || DEEPSEEK_API_KEY.includes("粘贴")) { 
        alert("请先填写有效的 API Key"); 
        return; 
    }
    const wl = parseInt(wordLimitInput.value);
    if (wl < 50 || wl > 500) { 
        alert("总结字数限制需在 50-500 之间"); 
        return; 
    }
    resultsDiv.innerHTML = "";
    selectBtn.disabled = true;
    
    for (const f of files) {
        resultsDiv.innerHTML = renderCard({ 
            filename: f.name, 
            ext:"-", 
            chars:"-", 
            paraCnt:"-", 
            sentCnt:"-", 
            preview:"读取中…", 
            summary:null, 
            keywords:null, 
            fullText:"" 
        });
        
        try {
            let text = "";
            const ext = f.name.split(".").pop().toLowerCase();
            
            if (ext === "txt") text = await readTxt(f);
            else if (ext === "docx") text = await readDocx(f);
            else if (ext === "pdf") text = await readPdf(f);
            else throw new Error("不支持的文件格式");
            
            const st = statText(text); // 精准句子统计
            const prev = text.slice(0,600) + (text.length>600?"…":"");
            
            resultsDiv.innerHTML = renderCard({ 
                filename:f.name, 
                ext, 
                ...st, 
                preview:prev, 
                summary:null, 
                keywords:null, 
                fullText:text 
            });
            
            const [sum, kw] = await Promise.all([aiSummary(text), extractKeywords(text)]);
            const final = { 
                filename:f.name, 
                ext, 
                ...st, 
                preview:prev, 
                summary:sum, 
                keywords:kw, 
                fullText:text 
            };
            
            resultsDiv.innerHTML = renderCard(final);
            saveHistory(final);
        } catch(e) {
            resultsDiv.innerHTML = renderCard({ 
                filename:f.name, 
                ext:"-", 
                chars:"-", 
                paraCnt:"-", 
                sentCnt:"-", 
                preview:"读取失败", 
                summary:e.message, 
                keywords:null, 
                fullText:"" 
            });
        }
    }
    selectBtn.disabled = false;
}
</script>
