<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <title>文档智能总结助手</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: "Microsoft YaHei", sans-serif;
            transition: background 0.2s, color 0.2s, border-color 0.2s;
        }

        :root {
            --bg: #f4f6fa;
            --card: #fff;
            --text: #334155;
            --text2: #475569;
            --text3: #64748b;
            --border: #e2e8f0;
            --blue: #3b82f6;
            --blue-hover: #2563eb;
            --gray: #94a3b8;
            --light-blue: #eff6ff;
            --preview-bg: #f8fafc;
        }

        [data-theme="dark"] {
            --bg: #1e1e2e;
            --card: #282838;
            --text: #e0e0e0;
            --text2: #c0c0d0;
            --text3: #a0a0b0;
            --border: #3f3f5f;
            --blue: #5b8cf7;
            --blue-hover: #4b7cf7;
            --light-blue: #2a3a5f;
            --preview-bg: #2d2d3f;
        }

        body {
            background: var(--bg);
            color: var(--text);
            padding: 30px;
        }

        .container {
            max-width: 1000px;
            margin: 0 auto;
            background: var(--card);
            border-radius: 12px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08);
            padding: 30px;
        }

        .header-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            gap: 12px;
        }

        h2 {
            color: var(--text);
            margin-bottom: 0;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .config-area {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            margin-bottom: 20px;
        }

        .config-item {
            flex: 1;
            min-width: 200px;
        }

        .config-item label {
            display: block;
            margin-bottom: 5px;
            color: var(--text2);
            font-size: 14px;
        }

        .config-item input, .config-item select {
            width: 100%;
            padding: 8px 10px;
            border: 1px solid var(--border);
            border-radius: 6px;
            font-size: 14px;
            background: var(--card);
            color: var(--text);
        }

        .drop-area {
            border: 2px dashed var(--border);
            border-radius: 8px;
            padding: 40px;
            text-align: center;
            margin-bottom: 30px;
            cursor: pointer;
        }

        .drop-area.dragover {
            border-color: var(--blue);
            background: var(--light-blue);
        }

        .drop-area p {
            color: var(--text3);
            margin-bottom: 15px;
        }

        .btn {
            background: var(--blue);
            color: #fff;
            border: none;
            padding: 10px 20px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 14px;
        }

        .btn:hover {
            background: var(--blue-hover);
        }

        .btn:disabled {
            background: var(--gray);
            cursor: not-allowed;
        }

        .btn-sm {
            padding: 6px 12px;
            font-size: 13px;
        }

        .card {
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 15px;
        }

        .card h4 {
            margin-bottom: 12px;
            color: var(--text);
            font-size: 16px;
        }

        .info {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 10px;
            margin: 10px 0;
            color: var(--text2);
            font-size: 14px;
        }

        .preview {
            background: var(--preview-bg);
            padding: 12px;
            border-radius: 6px;
            max-height: 160px;
            overflow-y: auto;
            font-size: 13px;
            color: var(--text);
            white-space: pre-wrap;
        }

        .summary {
            background: var(--light-blue);
            padding: 15px;
            border-radius: 8px;
            margin: 12px 0;
            border-left: 4px solid var(--blue);
            color: var(--text);
            max-height: 300px;
            overflow-y: auto;
            white-space: pre-wrap;
            line-height: 1.6;
        }

        .copy-row {
            display: flex;
            justify-content: flex-end;
            margin-top: 8px;
            gap: 8px;
        }

        .loading {
            color: var(--text3);
            font-style: italic;
        }

        .char-count {
            font-size: 12px;
            color: var(--text3);
            margin-top: 6px;
            text-align: right;
        }

        .keywords {
            margin-top: 8px;
            font-size: 14px;
            color: var(--text);
        }

        /* 翻译结果区样式 */
        .translate-panel {
            margin-top: 30px;
            padding: 15px;
            background: var(--light-blue);
            border-radius: 8px;
            border-left: 4px solid #8b5cf6;
        }

        .translate-panel h3 {
            font-size: 16px;
            margin-bottom: 10px;
            color: var(--text);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .translate-content {
            background: var(--card);
            padding: 12px;
            border-radius: 6px;
            max-height: 200px;
            overflow-y: auto;
            white-space: pre-wrap;
            line-height: 1.6;
            font-size: 14px;
        }

        .history-panel {
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid var(--border);
        }

        .history-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }

        .history-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
            max-height: 350px;
            overflow-y: auto;
        }

        .history-item {
            padding: 12px 15px;
            background: var(--preview-bg);
            border-radius: 6px;
            border-left: 3px solid var(--border);
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .history-item:hover {
            background: var(--light-blue);
        }

        .history-item.active {
            border-left-color: var(--blue);
            background: var(--light-blue);
        }

        .history-item .name {
            font-weight: 500;
            color: var(--text);
        }

        .history-item .time {
            font-size: 12px;
            color: var(--text3);
            margin-top: 4px;
        }

        .history-item .del {
            color: #ef4444;
            background: none;
            border: none;
            cursor: pointer;
            font-size: 12px;
        }

        .empty-history {
            text-align: center;
            color: var(--text3);
            padding: 20px;
        }

        .full-modal {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.5);
            display: flex; align-items: center; justify-content: center;
            z-index: 9999;
            display: none;
        }

        .full-box {
            background: var(--card);
            width: 90%; max-width: 800px;
            max-height: 80vh;
            border-radius: 10px;
            padding: 20px;
            overflow-y: auto;
        }

        .full-box h3 {
            margin-bottom: 12px;
        }

        .full-content {
            white-space: pre-wrap;
            font-size: 14px;
            line-height: 1.6;
        }

        .close-btn {
            margin-top: 12px;
            background: var(--border);
            border: none;
            padding: 6px 12px;
            border-radius: 6px;
            cursor: pointer;
        }

        .compare-panel {
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid var(--border);
        }

        .compare-boxes {
            display: flex;
            gap: 12px;
            margin-top: 12px;
        }

        .compare-box {
            flex: 1;
        }

        .compare-drop {
            border: 2px dashed var(--border);
            border-radius: 8px;
            padding: 20px;
            text-align: center;
            cursor: pointer;
        }

        .compare-drop.dragover {
            border-color: var(--blue);
            background: var(--light-blue);
        }

        .compare-bar {
            margin-top: 12px;
            text-align: center;
        }

        .compare-result {
            margin-top: 16px;
            padding: 16px;
            background: var(--light-blue);
            border-radius: 8px;
            white-space: pre-wrap;
            line-height: 1.6;
            font-size: 14px;
        }

        .theme-switch {
            background: var(--preview-bg);
            border: 1px solid var(--border);
            padding: 6px 10px;
            border-radius: 6px;
            cursor: pointer;
            color: var(--text);
        }

        /* 对比维度样式 */
        .compare-dimension {
            margin: 15px 0;
            padding: 10px;
            background: var(--preview-bg);
            border-radius: 6px;
        }

        .dimension-item {
            display: flex;
            align-items: center;
            margin: 5px 0;
            font-size: 14px;
        }

        .dimension-item input {
            margin-right: 8px;
        }
    </style>
</head>
<body>
