<script>
const DEEPSEEK_API_KEY = "YOUR API KEY";
const DEEPSEEK_URL = "https://api.deepseek.com/chat/completions";
const MODEL_NAME = "deepseek-chat";

// 全局变量
let currentTranslateContent = "";
let compareFile1 = { name: "", text: "", stat: null };
let compareFile2 = { name: "", text: "", stat: null };
let currentCompareResult = "";

// DOM 元素
const wordLimitInput = document.getElementById("wordLimit");
const styleSelect = document.getElementById("summaryStyle");
const dropArea = document.getElementById("dropArea");
const selectBtn = document.getElementById("selectBtn");
const resultsDiv = document.getElementById("results");
