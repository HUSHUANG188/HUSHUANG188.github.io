const fullTitle = document.getElementById("fullTitle");
const closeFull = document.getElementById("closeFull");

const compareDrop1 = document.getElementById("compareDrop1");
const compareSelect1 = document.getElementById("compareSelect1");
const compareDrop2 = document.getElementById("compareDrop2");
const compareSelect2 = document.getElementById("compareSelect2");
const startCompareBtn = document.getElementById("startCompareBtn");
const compareResult = document.getElementById("compareResult");
const exportCompareBtn = document.getElementById("exportCompareBtn");

// 对比维度
const dimContent = document.getElementById("dimContent");
const dimKeyword = document.getElementById("dimKeyword");
const dimView = document.getElementById("dimView");
